<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/floating_panel_bg"
    android:padding="20dp"
    android:elevation="24dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/panelHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="16dp">

        <!-- App icon dot -->
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="10dp"
            android:background="#0A84FF"
            android:elevation="1dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="VirtuCam"
            android:textColor="#F5F5F7"
            android:textSize="15sp"
            android:letterSpacing="0.02"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnMinimize"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/floating_icon_bg"
            android:contentDescription="Minimize"
            android:src="@android:drawable/ic_menu_view"
            android:tint="#EBEBF5"
            android:padding="6dp" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/floating_button_bg"
            android:contentDescription="Close"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#FF453A"
            android:padding="6dp" />
    </LinearLayout>

    <!-- Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1A2A"
        android:layout_marginBottom="16dp" />

    <!-- Scale Mode Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SCALE MODE"
        android:textColor="#636380"
        android:textSize="10sp"
        android:letterSpacing="0.12"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <!-- Scale Mode Segmented Control -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="@drawable/floating_segment_bg"
        android:padding="3dp"
        android:gravity="center"
        android:layout_marginBottom="18dp">

        <Button
            android:id="@+id/btnFit"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Fit"
            android:textColor="#EBEBF5"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="@drawable/floating_segment_active"
            android:letterSpacing="0.01" />

        <Button
            android:id="@+id/btnFill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Fill"
            android:textColor="#8E8EA0"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="@android:color/transparent"
            android:letterSpacing="0.01" />

        <Button
            android:id="@+id/btnStretch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Stretch"
            android:textColor="#8E8EA0"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="@android:color/transparent"
            android:letterSpacing="0.01" />
    </LinearLayout>

    <!-- Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1A2A"
        android:layout_marginBottom="16dp" />

    <!-- Axis Flip Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AXIS FLIP"
        android:textColor="#636380"
        android:textSize="10sp"
        android:letterSpacing="0.12"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <!-- Axis Flip Toggles -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="18dp"
        android:weightSum="2">

        <ToggleButton
            android:id="@+id/toggleMirrorH"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:textOn="Mirror H"
            android:textOff="Mirror H"
            android:textColor="#EBEBF5"
            android:textSize="12sp"
            android:background="@drawable/floating_button_bg" />

        <ToggleButton
            android:id="@+id/toggleFlipV"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:textOn="Flip V"
            android:textOff="Flip V"
            android:textColor="#EBEBF5"
            android:textSize="12sp"
            android:background="@drawable/floating_button_bg" />
    </LinearLayout>

    <!-- Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1A2A"
        android:layout_marginBottom="16dp" />

    <!-- Position Offset Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="POSITION OFFSET"
        android:textColor="#636380"
        android:textSize="10sp"
        android:letterSpacing="0.12"
        android:textStyle="bold"
        android:paddingBottom="10dp" />

    <!-- Offset Display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="10dp"
        android:background="@drawable/floating_icon_bg"
        android:paddingVertical="8dp"
        android:paddingHorizontal="12dp">

        <TextView
            android:id="@+id/txtOffsetX"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="X: 0"
            android:textColor="#F5F5F7"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center" />

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:background="#2A2A3A" />

        <TextView
            android:id="@+id/txtOffsetY"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Y: 0"
            android:textColor="#F5F5F7"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

    <!-- D-Pad Nudge Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Up -->
        <ImageButton
            android:id="@+id/btnNudgeUp"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/floating_button_bg"
            android:contentDescription="Nudge Up"
            android:src="@android:drawable/arrow_up_float"
            android:tint="#EBEBF5"
            android:layout_marginBottom="4dp" />

        <!-- Left + Center + Right Row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="4dp">

            <ImageButton
                android:id="@+id/btnNudgeLeft"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/floating_button_bg"
                android:contentDescription="Nudge Left"
                android:src="@android:drawable/ic_media_rew"
                android:tint="#EBEBF5"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnCenter"
                android:layout_width="64dp"
                android:layout_height="44dp"
                android:text="Center"
                android:textColor="#0A84FF"
                android:textSize="11sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:background="@drawable/floating_segment_active"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/btnNudgeRight"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/floating_button_bg"
                android:contentDescription="Nudge Right"
                android:src="@android:drawable/ic_media_ff"
                android:tint="#EBEBF5"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Down -->
        <ImageButton
            android:id="@+id/btnNudgeDown"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/floating_button_bg"
            android:contentDescription="Nudge Down"
            android:src="@android:drawable/arrow_down_float"
            android:tint="#EBEBF5" />
    </LinearLayout>

</LinearLayout>
