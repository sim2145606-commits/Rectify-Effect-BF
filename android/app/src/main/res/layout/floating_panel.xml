<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/floating_panel_bg"
    android:padding="16dp"
    android:elevation="12dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/panelHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="VirtuCam Tools"
            android:textColor="#F5F5F7"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnMinimize"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:contentDescription="Minimize"
            android:src="@android:drawable/ic_menu_view"
            android:tint="#8E8E93" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:contentDescription="Close"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#8E8E93" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A35"
        android:layout_marginBottom="12dp" />

    <!-- Scale Mode Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scale Mode"
        android:textColor="#8E8E93"
        android:textSize="12sp"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="16dp">

        <Button
            android:id="@+id/btnFit"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Fit"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="#3A3A48" />

        <Button
            android:id="@+id/btnFill"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="Fill"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="#3A3A48" />

        <Button
            android:id="@+id/btnStretch"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Stretch"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:background="#3A3A48" />
    </LinearLayout>

    <!-- Axis Toggles Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Axis Flip"
        android:textColor="#8E8E93"
        android:textSize="12sp"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="16dp">

        <ToggleButton
            android:id="@+id/toggleMirrorH"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:textOn="Mirror H"
            android:textOff="Mirror H"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="#3A3A48" />

        <ToggleButton
            android:id="@+id/toggleFlipV"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textOn="Flip V"
            android:textOff="Flip V"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="#3A3A48" />
    </LinearLayout>

    <!-- Position Offset Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Position Offset"
        android:textColor="#8E8E93"
        android:textSize="12sp"
        android:paddingBottom="8dp" />

    <!-- Offset Display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/txtOffsetX"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="X: 0"
            android:textColor="#F5F5F7"
            android:textSize="14sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/txtOffsetY"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Y: 0"
            android:textColor="#F5F5F7"
            android:textSize="14sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Nudge Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="8dp">

        <!-- Up Button -->
        <ImageButton
            android:id="@+id/btnNudgeUp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/floating_button_bg"
            android:contentDescription="Nudge Up"
            android:src="@android:drawable/arrow_up_float"
            android:tint="#FFFFFF"
            android:layout_marginBottom="4dp" />

        <!-- Left, Center, Right -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnNudgeLeft"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/floating_button_bg"
                android:contentDescription="Nudge Left"
                android:src="@android:drawable/ic_media_rew"
                android:tint="#FFFFFF"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnCenter"
                android:layout_width="60dp"
                android:layout_height="40dp"
                android:text="Center"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textAllCaps="false"
                android:background="@drawable/floating_icon_bg"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/btnNudgeRight"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/floating_button_bg"
                android:contentDescription="Nudge Right"
                android:src="@android:drawable/ic_media_ff"
                android:tint="#FFFFFF"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Down Button -->
        <ImageButton
            android:id="@+id/btnNudgeDown"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/floating_button_bg"
            android:contentDescription="Nudge Down"
            android:src="@android:drawable/arrow_down_float"
            android:tint="#FFFFFF"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</LinearLayout>
