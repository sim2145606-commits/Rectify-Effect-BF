<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="64dp"
    android:layout_height="64dp"
    android:padding="4dp">

    <!-- Outer ring / shadow layer -->
    <View
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:background="@drawable/floating_bubble_ring"
        android:elevation="6dp" />

    <!-- Main bubble background -->
    <View
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center"
        android:background="@drawable/floating_bubble_bg"
        android:elevation="8dp" />

    <!-- Camera icon -->
    <ImageView
        android:id="@+id/bubbleIcon"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center"
        android:contentDescription="VirtuCam Floating Controls"
        android:padding="14dp"
        android:src="@android:drawable/ic_menu_camera"
        android:tint="#FFFFFF"
        android:elevation="9dp" />

    <!-- Status dot indicator -->
    <View
        android:id="@+id/statusDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_gravity="top|end"
        android:layout_margin="8dp"
        android:background="@drawable/floating_status_dot"
        android:elevation="10dp" />

</FrameLayout>
