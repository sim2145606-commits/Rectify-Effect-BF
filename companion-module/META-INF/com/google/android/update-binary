#!/sbin/sh
# Standard Magisk/KSU/APatch module installer
# Compatible with Magisk, KernelSU, and APatch

SKIPUNZIP=1
ZIPFILE="${ZIPFILE:-$3}"
MODPATH="${MODPATH:-/data/adb/modules_update/virtucam_companion}"

mkdir -p "$MODPATH" 2>/dev/null

# Extract module files
unzip -o "$ZIPFILE" 'module.prop'     -d "$MODPATH" >/dev/null 2>&1
unzip -o "$ZIPFILE" 'customize.sh'    -d "$MODPATH" >/dev/null 2>&1
unzip -o "$ZIPFILE" 'post-fs-data.sh' -d "$MODPATH" >/dev/null 2>&1
unzip -o "$ZIPFILE" 'service.sh'      -d "$MODPATH" >/dev/null 2>&1
unzip -o "$ZIPFILE" 'action.sh'       -d "$MODPATH" >/dev/null 2>&1
unzip -o "$ZIPFILE" 'uninstall.sh'    -d "$MODPATH" >/dev/null 2>&1
unzip -o "$ZIPFILE" 'sepolicy.rule'   -d "$MODPATH" >/dev/null 2>&1
unzip -o "$ZIPFILE" 'update.json'     -d "$MODPATH" >/dev/null 2>&1
unzip -o "$ZIPFILE" 'webroot/*'       -d "$MODPATH" >/dev/null 2>&1

# Set executable permissions
chmod +x "$MODPATH/post-fs-data.sh" 2>/dev/null
chmod +x "$MODPATH/service.sh" 2>/dev/null
chmod +x "$MODPATH/action.sh" 2>/dev/null
chmod +x "$MODPATH/uninstall.sh" 2>/dev/null
chmod +x "$MODPATH/customize.sh" 2>/dev/null

# Run custom install logic
. "$MODPATH/customize.sh"
